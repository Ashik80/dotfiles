# background = "#11121d"
# foreground = "#a0a8cd"
background = "#181820"
foreground = "#dcd7ba"

# font-family = Roboto Mono Nerd Font
# font-family = Iosevka Custom
font-family = Iosevka Custom Semi-Extended
font-size = 17

adjust-cell-height = 10%
adjust-cursor-height = 10%
# adjust-cell-height = 30%
# adjust-cursor-height = 30%
cursor-style-blink = false
# custom-shader = shaders/cursor_smear.glsl

shell-integration-features = no-cursor

confirm-close-surface = false

# window-decoration = false
window-decoration = server

keybind = ctrl+page_up=unbind
keybind = ctrl+page_down=unbind
